{
  "manifest_version": 3,
  "name": "PathwiseAI YouTube Agent",
  "version": "1.0.1",
  "description": "Run the YouTube channel discovery agent; logs stream from your local PathwiseAI server.",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "PathwiseAI Agent",
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*"
  ],
  "permissions": ["storage"]
}
